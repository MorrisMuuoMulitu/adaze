# Adaze Marketplace Environment Variables (Vercel Stack)

# Database (Neon Serverless Postgres)
DATABASE_URL="postgresql://user:password@ep-random-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Use this for migrations or direct connections
DIRECT_URL="postgresql://user:password@ep-random-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Authentication (Auth.js)
AUTH_SECRET="your-32-char-random-string" # Generate with `openssl rand -base64 32`
NEXTAUTH_URL="http://localhost:3000"

# Blob Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# AI (Vercel AI SDK)
OPENAI_API_KEY="sk-..."

# Payment (M-Pesa)
NEXT_PUBLIC_MPESA_CONSUMER_KEY="your_consumer_key"
MPESA_CONSUMER_SECRET="your_consumer_secret"
MPESA_PASSKEY="your_passkey"
NEXT_PUBLIC_MPESA_SHORTCODE="174379"
NEXT_PUBLIC_MPESA_ENV="sandbox"
NEXT_PUBLIC_MPESA_CALLBACK_URL="https://your-domain.com/api/mpesa/callback"

# Legacy (Supabase - Keep until fully migrated)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
