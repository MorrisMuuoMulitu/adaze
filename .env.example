# Adaze Marketplace Environment Variables (Vercel Stack)

# Database (Neon Serverless Postgres)
# Get this from your Neon project dashboard
DATABASE_URL="postgresql://user:password@ep-random-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"
# Use this for migrations or direct connections
DIRECT_URL="postgresql://user:password@ep-random-name-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Authentication (Auth.js / NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-random-string"
# The URL of your site (required for Auth.js in production)
NEXTAUTH_URL="https://your-domain.vercel.app"
AUTH_TRUST_HOST=true

# AI & Search (OpenAI)
# Required for /api/search and /api/ai/generate-description
OPENAI_API_KEY="sk-..."

# Blob Storage (Vercel Blob)
# Required for product images and avatars
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Notifications & Email (Resend)
# Required for email notifications via notificationService
RESEND_API_KEY="re_..."

# Payment (M-Pesa Daraja API)
# Get these from Safaricom Developer Portal
NEXT_PUBLIC_MPESA_CONSUMER_KEY="your_consumer_key"
MPESA_CONSUMER_SECRET="your_consumer_secret"
MPESA_PASSKEY="your_passkey"
NEXT_PUBLIC_MPESA_SHORTCODE="174379"
NEXT_PUBLIC_MPESA_ENV="sandbox" # 'sandbox' or 'production'
# Override callback URL if needed, otherwise it's auto-generated from VERCEL_URL
NEXT_PUBLIC_MPESA_CALLBACK_URL="https://your-domain.com/api/mpesa/callback"

# General
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# Legacy (Supabase - Optional, keeping for transition)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
