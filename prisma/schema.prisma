generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String               @id @default(uuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 Role                 @default(BUYER)
  phone                String?
  location             String?
  isVerified           Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  isSuspended          Boolean              @default(false)
  suspendedAt          DateTime?
  suspendedBy          String?
  isDeleted            Boolean              @default(false)
  deletedAt            DateTime?
  deletedBy            String?
  lastLoginAt          DateTime?
  loginCount           Int                  @default(0)
  twoFactorEnabled     Boolean              @default(false)
  twoFactorMethod      String?              @default("totp")
  twoFactorSecret      String?
  accounts             Account[]
  cart                 CartItem[]
  loginHistory         LoginHistory[]
  mpesaTransactions    MpesaTransaction[]
  notifications        Notification[]
  ordersAsBuyer        Order[]              @relation("BuyerOrders")
  ordersAsTrader       Order[]              @relation("TraderOrders")
  ordersAsTransporter  Order[]              @relation("TransporterOrders")
  products             Product[]            @relation("TraderProducts")
  reviewsReceived      Review[]             @relation("Reviewed")
  reviewsGiven         Review[]             @relation("Reviewer")
  helpfulMarks         ReviewHelpful[]
  passwordResetTokens  PasswordResetToken[]
  conversationsAsBuyer Conversation[]       @relation("BuyerConversations")
  conversationsAsTrader Conversation[]      @relation("TraderConversations")
  sentMessages         Message[]
  sessions             Session[]
  suspiciousActivities SuspiciousActivity[]
  wishlist             Wishlist[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id              String   @id @default(uuid())
  sessionToken    String   @unique
  userId          String
  expires         DateTime
  browser         String?
  deviceName      String?
  deviceType      String?
  ipAddress       String?
  isActive        Boolean  @default(true)
  lastActivityAt  DateTime @default(now())
  locationCity    String?
  locationCountry String?
  os              String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model LoginHistory {
  id              String      @id @default(uuid())
  userId          String
  loginTime       DateTime    @default(now())
  ipAddress       String?
  userAgent       String?
  deviceType      String?
  browser         String?
  os              String?
  locationCountry String?
  locationCity    String?
  status          LoginStatus
  isSuspicious    Boolean     @default(false)
  riskScore       Int         @default(0)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_history")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id            String        @id @default(uuid())
  traderId      String
  name          String
  description   String?
  price         Decimal       @db.Decimal(10, 2)
  category      String?
  imageUrl      String?
  stockQuantity Int           @default(0)
  rating        Decimal       @default(0.0) @db.Decimal(2, 1)
  viewCount     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  isFeatured    Boolean       @default(false)
  status        ProductStatus @default(PENDING)
  cartItems     CartItem[]
  orderItems    OrderItem[]
  trader        User          @relation("TraderProducts", fields: [traderId], references: [id])
  reviews       Review[]
  wishlist      Wishlist[]
  views         ProductView[]
  conversations Conversation[]

  @@index([name])
  @@index([category])
  @@index([traderId])
  @@map("products")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

model Wishlist {
  id                String    @id @default(uuid())
  userId            String
  productId         String
  notifyOnPriceDrop Boolean   @default(false)
  originalPrice     Decimal?  @db.Decimal(10, 2)
  targetPrice       Decimal?  @db.Decimal(10, 2)
  lastNotifiedAt    DateTime?
  createdAt         DateTime  @default(now())
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([notifyOnPriceDrop])
  @@map("wishlist")
}

model ReviewHelpful {
  id        String   @id @default(uuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@map("review_helpful")
}

model ProductView {
  id        String   @id @default(uuid())
  productId String
  userId    String?
  sessionId String?
  viewedAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([viewedAt])
  @@map("product_views")
}

model Conversation {
  id        String    @id @default(uuid())
  buyerId   String
  traderId  String
  orderId   String?
  productId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  buyer    User      @relation("BuyerConversations", fields: [buyerId], references: [id])
  trader   User      @relation("TraderConversations", fields: [traderId], references: [id])
  order    Order?    @relation(fields: [orderId], references: [id])
  product  Product?  @relation(fields: [productId], references: [id])
  messages Message[]

  @@index([buyerId])
  @@index([traderId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  attachments    String[]
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model Order {
  id                String             @id @default(uuid())
  buyerId           String
  traderId          String?
  transporterId     String?
  title             String
  description       String?
  amount            Decimal            @db.Decimal(10, 2)
  status            OrderStatus        @default(PENDING)
  shippingAddress   String
  billingAddress    String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  mpesaTransactions MpesaTransaction[]
  items             OrderItem[]
  buyer             User               @relation("BuyerOrders", fields: [buyerId], references: [id])
  trader            User?              @relation("TraderOrders", fields: [traderId], references: [id])
  transporter       User?              @relation("TransporterOrders", fields: [transporterId], references: [id])
  reviews           Review[]
  conversations     Conversation[]

  @@index([buyerId])
  @@index([traderId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  priceAtTime Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Review {
  id                 String    @id @default(uuid())
  orderId            String?
  productId          String?
  reviewerId         String
  reviewedId         String
  rating             Int
  title              String?
  comment            String?
  images             String[]  @default([])
  verifiedPurchase   Boolean   @default(false)
  helpfulCount       Int       @default(0)
  traderResponse     String?
  traderResponseDate DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  order              Order?    @relation(fields: [orderId], references: [id])
  product            Product?  @relation(fields: [productId], references: [id])
  reviewed           User      @relation("Reviewed", fields: [reviewedId], references: [id])
  reviewer           User      @relation("Reviewer", fields: [reviewerId], references: [id])
  helpfulMarks       ReviewHelpful[]

  @@index([productId])
  @@index([reviewedId])
  @@index([createdAt])
  @@map("reviews")
}

model Notification {
  id             String           @id @default(uuid())
  userId         String
  title          String
  message        String
  type           NotificationType @default(INFO)
  isRead         Boolean          @default(false)
  relatedOrderId String?
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model MpesaTransaction {
  id                 String      @id @default(uuid())
  orderId            String
  userId             String
  amount             Decimal     @db.Decimal(10, 2)
  phoneNumber        String
  checkoutRequestId  String      @unique
  merchantRequestId  String
  mpesaReceiptNumber String?
  status             MpesaStatus @default(PENDING)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  order              Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([checkoutRequestId])
  @@index([status])
  @@map("mpesa_transactions")
}

model SuspiciousActivity {
  id          String    @id @default(uuid())
  userId      String?
  type        String
  description String
  ipAddress   String?
  userAgent   String?
  severity    String    @default("low")
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("suspicious_activities")
}

model PlatformSettings {
  id                  String   @id @default("default")
  siteName            String   @default("Adaze Marketplace")
  maintenanceMode     Boolean  @default(false)
  allowRegistration   Boolean  @default(true)
  commissionRate      Decimal  @default(10.0) @db.Decimal(5, 2)
  minWithdrawalAmount Decimal  @default(1000.0) @db.Decimal(10, 2)
  supportEmail        String?
  updatedAt           DateTime @updatedAt

  @@map("platform_settings")
}

enum Role {
  BUYER
  TRADER
  TRANSPORTER
  ADMIN
  WHOLESALER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  PRICE_DROP
  NEW_MESSAGE
  ORDER_UPDATE
}

enum MpesaStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum LoginStatus {
  SUCCESS
  FAILED
  BLOCKED
}

enum ProductStatus {
  ACTIVE
  PENDING
  REJECTED
}
